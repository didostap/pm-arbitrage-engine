# Application
NODE_ENV=development
PORT=8080

# Database (localhost for local dev, postgres service name for Docker)
DATABASE_URL="postgresql://postgres:password@localhost:5433/pmarbitrage?schema=public"

# Trading Engine
POLLING_INTERVAL_MS=30000  # 30 seconds for MVP

# Kalshi API Configuration
KALSHI_API_KEY_ID=your-key-id-here
KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi-demo-key.pem
KALSHI_API_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_API_TIER=BASIC

# Polymarket Configuration
POLYMARKET_PRIVATE_KEY=
POLYMARKET_CLOB_API_URL=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_CHAIN_ID=137

# Edge Calculation (Story 3.3)
DETECTION_MIN_EDGE_THRESHOLD=0.008
DETECTION_GAS_ESTIMATE_USD=0.30
DETECTION_POSITION_SIZE_USD=300

# Gas Estimation (Story 6.0)
POLYMARKET_RPC_URL=https://polygon-rpc.com
GAS_BUFFER_PERCENT=20
GAS_POLL_INTERVAL_MS=30000
GAS_POL_PRICE_FALLBACK_USD=0.40
POLYMARKET_SETTLEMENT_GAS_UNITS=150000

# Capital Efficiency (Story 9.5, FR-AD-08)
MIN_ANNUALIZED_RETURN=0.15

# Risk Management (Story 4.1)
RISK_BANKROLL_USD=10000
RISK_MAX_POSITION_PCT=0.03
RISK_MAX_OPEN_PAIRS=10
RISK_DAILY_LOSS_PCT=0.05

# Operator API Authentication (Story 4.3)
OPERATOR_API_TOKEN=dev-token-change-me

# Paper Trading Mode (Story 5.5.1)
PLATFORM_MODE_KALSHI=paper             # Dev default: paper mode
PLATFORM_MODE_POLYMARKET=paper         # Dev default: paper mode
PAPER_FILL_LATENCY_MS_KALSHI=150       # Simulated fill latency in ms
PAPER_SLIPPAGE_BPS_KALSHI=5            # Simulated slippage in basis points
PAPER_FILL_LATENCY_MS_POLYMARKET=800   # Simulated fill latency in ms (reflects on-chain)
PAPER_SLIPPAGE_BPS_POLYMARKET=15       # Simulated slippage in basis points
ALLOW_MIXED_MODE=true                  # Dev default: mixed mode allowed

# Telegram Alerts (Story 6.1) — disabled in dev by default (empty token/chatId)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TEST_ALERT_CRON=0 8 * * *
TELEGRAM_TEST_ALERT_TIMEZONE=UTC
TELEGRAM_SEND_TIMEOUT_MS=2000
TELEGRAM_MAX_RETRIES=3
TELEGRAM_BUFFER_MAX_SIZE=100
TELEGRAM_CIRCUIT_BREAK_MS=60000

# CSV Trade Logging (Story 6.3)
CSV_TRADE_LOG_DIR=./data/trade-logs
CSV_ENABLED=true
# Daily summary runs at UTC midnight (hardcoded @Cron in DailySummaryService)

# Compliance Validation (Story 6.4)
COMPLIANCE_MATRIX_CONFIG_PATH=config/compliance-matrix.yaml

# Dashboard (Story 7.1)
DASHBOARD_ORIGIN=http://localhost:3000

# LLM Confidence Scoring (Story 8.2)
LLM_PRIMARY_PROVIDER=gemini
LLM_PRIMARY_MODEL=gemini-2.5-flash
LLM_PRIMARY_API_KEY=
LLM_ESCALATION_PROVIDER=anthropic
LLM_ESCALATION_MODEL=claude-haiku-4-5-20251001
LLM_ESCALATION_API_KEY=
LLM_ESCALATION_MIN=60
LLM_ESCALATION_MAX=84
LLM_AUTO_APPROVE_THRESHOLD=85
LLM_MIN_REVIEW_THRESHOLD=40
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_MS=30000

# Discovery Pipeline (Story 8.4)
DISCOVERY_ENABLED=true
DISCOVERY_RUN_ON_STARTUP=false
DISCOVERY_CRON_EXPRESSION=0 0 8,20 * * *
DISCOVERY_PREFILTER_THRESHOLD=0.25
DISCOVERY_SETTLEMENT_WINDOW_DAYS=7
DISCOVERY_MAX_CANDIDATES_PER_CONTRACT=20
DISCOVERY_LLM_CONCURRENCY=10
POLYMARKET_GAMMA_API_URL=https://gamma-api.polymarket.com

# Resolution Polling (Story 8.3)
RESOLUTION_POLLER_ENABLED=true
RESOLUTION_POLLER_CRON_EXPRESSION=0 0 6 * * *
RESOLUTION_POLLER_BATCH_SIZE=100

# Calibration Analysis (Story 8.3)
CALIBRATION_ENABLED=true
CALIBRATION_CRON_EXPRESSION=0 0 7 1 */3 *

# Audit Log Retention (Story 9.6)
AUDIT_LOG_RETENTION_DAYS=7                          # 0 = disabled (for Phase 1+ 7-year retention compliance)

# Stress Testing (Story 9.4)
STRESS_TEST_SCENARIOS=1000
STRESS_TEST_DEFAULT_DAILY_VOL=0.03
STRESS_TEST_MIN_SNAPSHOTS=30

# Auto-Unwind (Story 10.3) — automatic single-leg management
AUTO_UNWIND_ENABLED=false                          # Dev default: disabled (explicit opt-in)
AUTO_UNWIND_DELAY_MS=2000                          # Delay before auto-unwind action (ms)
AUTO_UNWIND_MAX_LOSS_PCT=5                         # Max acceptable loss as % of leg value

# Exit Mode (Story 10.2) — five-criteria model-driven exit logic
EXIT_MODE=shadow                                    # Dev default: shadow mode (accumulate comparison data)
EXIT_EDGE_EVAP_MULTIPLIER=-1.0
EXIT_CONFIDENCE_DROP_PCT=20
EXIT_TIME_DECAY_HORIZON_H=168
EXIT_TIME_DECAY_STEEPNESS=2.0
EXIT_TIME_DECAY_TRIGGER=0.8
EXIT_RISK_BUDGET_PCT=85
EXIT_RISK_RANK_CUTOFF=1
EXIT_MIN_DEPTH=5
EXIT_PROFIT_CAPTURE_RATIO=0.5

# Data Divergence Detection (Story 10-0-1) — poll vs WebSocket data path comparison
DIVERGENCE_PRICE_THRESHOLD=0.02                    # Price delta threshold (decimal, 0.02 = 2%)
DIVERGENCE_STALENESS_THRESHOLD_MS=90000            # Staleness delta threshold (ms)
