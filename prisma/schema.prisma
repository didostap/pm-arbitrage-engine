// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Platform enum for type-safe platform identification
enum Platform {
  KALSHI
  POLYMARKET
}

// Engine configuration singleton — typed config persisted in DB (replaces SystemMetadata placeholder)
// Story 10-5.1: Expanded with 71 Category B operator-tunable columns (all nullable for migration safety)
model EngineConfig {
  id               String   @id @default(uuid()) @map("id")
  singletonKey     String   @unique @default("default") @map("singleton_key")
  bankrollUsd      Decimal  @map("bankroll_usd") @db.Decimal(20, 8)
  paperBankrollUsd Decimal? @map("paper_bankroll_usd") @db.Decimal(20, 8)

  // --- Trading Engine (1) ---
  pollingIntervalMs Int? @map("polling_interval_ms")

  // --- Edge Detection (4) ---
  detectionMinEdgeThreshold Decimal? @map("detection_min_edge_threshold") @db.Decimal(20, 8)
  detectionGasEstimateUsd   Decimal? @map("detection_gas_estimate_usd") @db.Decimal(20, 8)
  detectionPositionSizeUsd  Decimal? @map("detection_position_size_usd") @db.Decimal(20, 8)
  minAnnualizedReturn       Decimal? @map("min_annualized_return") @db.Decimal(20, 8)
  detectionMinFillRatio     Decimal? @map("detection_min_fill_ratio") @db.Decimal(20, 8)

  // --- Gas Estimation (4) ---
  gasBufferPercent             Int?     @map("gas_buffer_percent")
  gasPollIntervalMs            Int?     @map("gas_poll_interval_ms")
  gasPolPriceFallbackUsd       Decimal? @map("gas_pol_price_fallback_usd") @db.Decimal(20, 8)
  polymarketSettlementGasUnits Int?     @map("polymarket_settlement_gas_units")

  // --- Execution (2) ---
  executionMinFillRatio    Decimal? @map("execution_min_fill_ratio") @db.Decimal(20, 8)
  dualLegMinDepthRatio     Decimal? @map("dual_leg_min_depth_ratio") @db.Decimal(20, 8)

  // --- Risk Management (3, bankroll already exists) ---
  riskMaxPositionPct Decimal? @map("risk_max_position_pct") @db.Decimal(20, 8)
  riskMaxOpenPairs   Int?     @map("risk_max_open_pairs")
  riskDailyLossPct   Decimal? @map("risk_daily_loss_pct") @db.Decimal(20, 8)

  // --- Correlation Clusters (4) ---
  clusterLlmTimeoutMs          Int?     @map("cluster_llm_timeout_ms")
  riskClusterHardLimitPct      Decimal? @map("risk_cluster_hard_limit_pct") @db.Decimal(20, 8)
  riskClusterSoftLimitPct      Decimal? @map("risk_cluster_soft_limit_pct") @db.Decimal(20, 8)
  riskAggregateClusterLimitPct Decimal? @map("risk_aggregate_cluster_limit_pct") @db.Decimal(20, 8)

  // --- Telegram (6, tokens/chatId stay as env secrets) ---
  telegramTestAlertCron     String? @map("telegram_test_alert_cron")
  telegramTestAlertTimezone String? @map("telegram_test_alert_timezone")
  telegramSendTimeoutMs     Int?    @map("telegram_send_timeout_ms")
  telegramMaxRetries        Int?    @map("telegram_max_retries")
  telegramBufferMaxSize     Int?    @map("telegram_buffer_max_size")
  telegramCircuitBreakMs    Int?    @map("telegram_circuit_break_ms")

  // --- CSV Logging (1) ---
  csvEnabled Boolean? @map("csv_enabled")

  // --- LLM Scoring (10, API keys stay as env secrets) ---
  llmPrimaryProvider     String? @map("llm_primary_provider")
  llmPrimaryModel        String? @map("llm_primary_model")
  llmEscalationProvider  String? @map("llm_escalation_provider")
  llmEscalationModel     String? @map("llm_escalation_model")
  llmEscalationMin       Int?    @map("llm_escalation_min")
  llmEscalationMax       Int?    @map("llm_escalation_max")
  llmAutoApproveThreshold Int?   @map("llm_auto_approve_threshold")
  llmMinReviewThreshold  Int?    @map("llm_min_review_threshold")
  llmMaxTokens           Int?    @map("llm_max_tokens")
  llmTimeoutMs           Int?    @map("llm_timeout_ms")

  // --- Discovery (7) ---
  discoveryEnabled                 Boolean? @map("discovery_enabled")
  discoveryRunOnStartup            Boolean? @map("discovery_run_on_startup")
  discoveryCronExpression          String?  @map("discovery_cron_expression")
  discoveryPrefilterThreshold      Decimal? @map("discovery_prefilter_threshold") @db.Decimal(20, 8)
  discoverySettlementWindowDays    Int?     @map("discovery_settlement_window_days")
  discoveryMaxCandidatesPerContract Int?    @map("discovery_max_candidates_per_contract")
  discoveryLlmConcurrency          Int?     @map("discovery_llm_concurrency")

  // --- Resolution Polling (3) ---
  resolutionPollerEnabled        Boolean? @map("resolution_poller_enabled")
  resolutionPollerCronExpression String?  @map("resolution_poller_cron_expression")
  resolutionPollerBatchSize      Int?     @map("resolution_poller_batch_size")

  // --- Calibration (2) ---
  calibrationEnabled        Boolean? @map("calibration_enabled")
  calibrationCronExpression String?  @map("calibration_cron_expression")

  // --- Staleness Thresholds (2) ---
  orderbookStalenessThresholdMs Int? @map("orderbook_staleness_threshold_ms")
  wsStalenessThresholdMs        Int? @map("ws_staleness_threshold_ms")

  // --- Polling Concurrency (2) ---
  kalshiPollingConcurrency     Int? @map("kalshi_polling_concurrency")
  polymarketPollingConcurrency Int? @map("polymarket_polling_concurrency")

  // --- Pair Concentration Limits (3) ---
  pairCooldownMinutes        Int? @map("pair_cooldown_minutes")
  pairMaxConcurrentPositions Int? @map("pair_max_concurrent_positions")
  pairDiversityThreshold     Int? @map("pair_diversity_threshold")

  // --- Audit Log (1) ---
  auditLogRetentionDays Int? @map("audit_log_retention_days")

  // --- Stress Testing (3) ---
  stressTestScenarios       Int?     @map("stress_test_scenarios")
  stressTestDefaultDailyVol Decimal? @map("stress_test_default_daily_vol") @db.Decimal(20, 8)
  stressTestMinSnapshots    Int?     @map("stress_test_min_snapshots")

  // --- Auto-Unwind (3) ---
  autoUnwindEnabled    Boolean? @map("auto_unwind_enabled")
  autoUnwindDelayMs    Int?     @map("auto_unwind_delay_ms")
  autoUnwindMaxLossPct Float?   @map("auto_unwind_max_loss_pct")

  // --- Adaptive Sequencing (2) ---
  adaptiveSequencingEnabled              Boolean? @map("adaptive_sequencing_enabled")
  adaptiveSequencingLatencyThresholdMs   Int?     @map("adaptive_sequencing_latency_threshold_ms")

  // --- Polymarket Order Polling (2) ---
  polymarketOrderPollTimeoutMs  Int? @map("polymarket_order_poll_timeout_ms")
  polymarketOrderPollIntervalMs Int? @map("polymarket_order_poll_interval_ms")

  // --- Exit Mode (10) ---
  exitMode                String? @map("exit_mode")
  exitEdgeEvapMultiplier  Float?  @map("exit_edge_evap_multiplier")
  exitConfidenceDropPct   Int?    @map("exit_confidence_drop_pct")
  exitTimeDecayHorizonH   Int?    @map("exit_time_decay_horizon_h")
  exitTimeDecaySteepness  Float?  @map("exit_time_decay_steepness")
  exitTimeDecayTrigger    Float?  @map("exit_time_decay_trigger")
  exitRiskBudgetPct       Int?    @map("exit_risk_budget_pct")
  exitRiskRankCutoff      Int?    @map("exit_risk_rank_cutoff")
  exitMinDepth                 Int?    @map("exit_min_depth")
  exitDepthSlippageTolerance   Float?  @map("exit_depth_slippage_tolerance")
  exitMaxChunkSize             Int?    @map("exit_max_chunk_size")
  exitProfitCaptureRatio       Float?  @map("exit_profit_capture_ratio")

  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("engine_config")
}

// Order book snapshots for audit trail and compliance (7-year retention)
// DESIGN DECISION: Store full depth (bids/asks arrays as JSON) not just best prices
// - Justification: Epic 3's edge calculator needs "liquidity depth at execution prices" (FR-AD-02)
// - Storage cost: ~1-2KB per snapshot vs ~100 bytes for best-only
// - Query pattern: Primarily time-series append, rare queries, acceptable trade-off
model OrderBookSnapshot {
  id              String   @id @default(uuid())
  platform        Platform // Platform enum: KALSHI | POLYMARKET
  contract_id     String // Platform's contract identifier
  bids            Json // PriceLevel[] serialized: [{price: 0.60, quantity: 1000}, ...]
  asks            Json // PriceLevel[] serialized: [{price: 0.65, quantity: 800}, ...]
  sequence_number Int? // Optional WebSocket sequence tracking
  created_at      DateTime @default(now()) @db.Timestamptz

  @@index([platform, contract_id, created_at])
  @@index([created_at]) // For retention policy cleanup (7-year window)
  @@map("order_book_snapshots")
}

// Platform health logs for observability and degradation analysis
model PlatformHealthLog {
  id               String   @id @default(uuid())
  platform         Platform // Platform enum: KALSHI | POLYMARKET
  status           String // "healthy" | "degraded" | "disconnected" (NOT "offline")
  last_update      DateTime @db.Timestamptz
  response_time_ms Float? // p95 latency
  connection_state String // From connector.getHealth() metadata
  created_at       DateTime @default(now()) @db.Timestamptz

  @@index([platform, created_at])
  @@index([created_at])
  @@map("platform_health_logs")
}

// Correlation cluster for grouping related contract matches by risk factor
model CorrelationCluster {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  contractMatches ContractMatch[]
  tagMappings     ClusterTagMapping[]

  @@map("correlation_clusters")
}

// Maps platform-specific raw categories to correlation clusters for deterministic fast-path classification
model ClusterTagMapping {
  id          String   @id @default(uuid())
  clusterId   String   @map("cluster_id")
  platform    String // "kalshi" | "polymarket"
  rawCategory String   @map("raw_category")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  cluster CorrelationCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@unique([clusterId, platform, rawCategory])
  @@map("cluster_tag_mappings")
}

// Contract match pairs tracking operator-approved cross-platform matches
model ContractMatch {
  matchId                   String    @id @default(uuid()) @map("match_id")
  polymarketContractId      String    @map("polymarket_contract_id")
  polymarketClobTokenId     String?   @map("polymarket_clob_token_id")
  kalshiContractId          String    @map("kalshi_contract_id")
  polymarketDescription     String?   @map("polymarket_description")
  kalshiDescription         String?   @map("kalshi_description")
  polymarketRawCategory     String?   @map("polymarket_raw_category")
  kalshiRawCategory         String?   @map("kalshi_raw_category")
  operatorApproved          Boolean   @default(false) @map("operator_approved")
  operatorApprovalTimestamp DateTime? @map("operator_approval_timestamp") @db.Timestamptz
  operatorRationale         String?   @map("operator_rationale")
  firstTradedTimestamp      DateTime? @map("first_traded_timestamp") @db.Timestamptz
  totalCyclesTraded         Int       @default(0) @map("total_cycles_traded")
  primaryLeg                String?   @map("primary_leg") // "kalshi" | "polymarket", default applied in ExecutionService
  resolutionDate            DateTime? @map("resolution_date") @db.Timestamptz
  confidenceScore           Float?    @map("confidence_score")
  resolutionCriteriaHash    String?   @map("resolution_criteria_hash")
  polymarketResolution      String?   @map("polymarket_resolution")
  kalshiResolution          String?   @map("kalshi_resolution")
  resolutionTimestamp       DateTime? @map("resolution_timestamp") @db.Timestamptz
  resolutionDiverged        Boolean?  @map("resolution_diverged")
  divergenceNotes           String?   @map("divergence_notes")
  polymarketOutcomeLabel    String?   @map("polymarket_outcome_label")
  kalshiOutcomeLabel        String?   @map("kalshi_outcome_label")
  clusterId                 String?   @map("cluster_id")
  lastAnnualizedReturn      Decimal?  @map("last_annualized_return") @db.Decimal(20, 8)
  lastNetEdge               Decimal?  @map("last_net_edge") @db.Decimal(20, 8)
  lastComputedAt            DateTime? @map("last_computed_at") @db.Timestamptz
  createdAt                 DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  cluster   CorrelationCluster? @relation(fields: [clusterId], references: [id], onDelete: SetNull)
  orders    Order[]
  positions OpenPosition[]

  @@unique([polymarketContractId, kalshiContractId])
  @@index([operatorApproved])
  @@index([polymarketClobTokenId])
  @@index([resolutionDiverged])
  @@index([confidenceScore])
  @@index([resolutionTimestamp])
  @@index([clusterId])
  @@index([lastAnnualizedReturn])
  @@index([lastNetEdge])
  @@index([lastComputedAt])
  @@map("contract_matches")
}

// Risk state singleton for tracking position counts and capital deployment
model RiskState {
  id                    String    @id @default(uuid()) @map("id")
  singletonKey          String    @default("default") @map("singleton_key")
  mode                  String    @default("live") @map("mode")
  dailyPnl              Decimal   @default(0) @map("daily_pnl") @db.Decimal(20, 8)
  openPositionCount     Int       @default(0) @map("open_position_count")
  lastResetTimestamp    DateTime? @map("last_reset_timestamp") @db.Timestamptz
  totalCapitalDeployed  Decimal   @default(0) @map("total_capital_deployed") @db.Decimal(20, 8)
  tradingHalted         Boolean   @default(false) @map("trading_halted")
  haltReason            String?   @map("halt_reason")
  reservedCapital       Decimal   @default(0) @map("reserved_capital") @db.Decimal(20, 8)
  reservedPositionSlots Int       @default(0) @map("reserved_position_slots")
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([singletonKey, mode])
  @@map("risk_states")
}

// Order status enum for tracking order lifecycle
enum OrderStatus {
  PENDING
  FILLED
  PARTIAL
  REJECTED
  CANCELLED
}

// Position status enum for tracking position lifecycle
enum PositionStatus {
  OPEN
  SINGLE_LEG_EXPOSED
  EXIT_PARTIAL
  CLOSED
  RECONCILIATION_REQUIRED
}

// Individual orders submitted to platforms
model Order {
  orderId    String      @id @default(uuid()) @map("order_id")
  platform   Platform
  contractId String      @map("contract_id")
  pairId     String      @map("pair_id")
  side       String // 'buy' | 'sell'
  price      Decimal     @db.Decimal(20, 8)
  size       Decimal     @db.Decimal(20, 8)
  status     OrderStatus
  fillPrice  Decimal?    @map("fill_price") @db.Decimal(20, 8)
  fillSize   Decimal?    @map("fill_size") @db.Decimal(20, 8)
  isPaper    Boolean     @default(false) @map("is_paper")
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  pair ContractMatch @relation(fields: [pairId], references: [matchId])

  polymarketPositions OpenPosition[] @relation("PolymarketOrder")
  kalshiPositions     OpenPosition[] @relation("KalshiOrder")

  @@index([pairId])
  @@index([platform, status])
  @@index([createdAt])
  @@index([isPaper, status])
  @@map("orders")
}

// Open positions tracking two-leg (or single-leg) arbitrage positions
model OpenPosition {
  positionId        String         @id @default(uuid()) @map("position_id")
  pairId            String         @map("pair_id")
  polymarketOrderId String?        @map("polymarket_order_id")
  kalshiOrderId     String?        @map("kalshi_order_id")
  polymarketSide    String?        @map("polymarket_side")
  kalshiSide        String?        @map("kalshi_side")
  entryPrices       Json           @map("entry_prices") // {polymarket: string, kalshi: string}
  sizes             Json // {polymarket: string, kalshi: string}
  expectedEdge      Decimal        @map("expected_edge") @db.Decimal(20, 8)
  realizedPnl       Decimal?       @map("realized_pnl") @db.Decimal(20, 8)
  status            PositionStatus
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  reconciliationContext Json? @map("reconciliation_context")
  executionMetadata    Json? @map("execution_metadata")
  isPaper           Boolean        @default(false) @map("is_paper")

  entryClosePriceKalshi      Decimal? @map("entry_close_price_kalshi") @db.Decimal(20, 8)
  entryClosePricePolymarket  Decimal? @map("entry_close_price_polymarket") @db.Decimal(20, 8)
  entryKalshiFeeRate         Decimal? @map("entry_kalshi_fee_rate") @db.Decimal(20, 8)
  entryPolymarketFeeRate     Decimal? @map("entry_polymarket_fee_rate") @db.Decimal(20, 8)

  recalculatedEdge         Decimal?   @map("recalculated_edge") @db.Decimal(20, 8)
  lastRecalculatedAt       DateTime?  @map("last_recalculated_at") @db.Timestamptz
  recalculationDataSource  String?    @map("recalculation_data_source") @db.VarChar(20)

  // Five-criteria model fields (Story 10.2)
  entryConfidenceScore     Float?     @map("entry_confidence_score")
  lastEvalCriteria         Json?      @map("last_eval_criteria")
  exitMode                 String?    @map("exit_mode") @db.VarChar(10)

  pair            ContractMatch @relation(fields: [pairId], references: [matchId])
  polymarketOrder Order?        @relation("PolymarketOrder", fields: [polymarketOrderId], references: [orderId])
  kalshiOrder     Order?        @relation("KalshiOrder", fields: [kalshiOrderId], references: [orderId])

  @@index([pairId])
  @@index([status])
  @@index([createdAt])
  @@index([isPaper, status])
  @@map("open_positions")
}

// Tamper-evident audit trail with SHA-256 hash chain (NFR-S3: 7-year retention)
model AuditLog {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  eventType     String   @map("event_type")
  module        String
  correlationId String?  @map("correlation_id")
  details       Json
  previousHash  String   @map("previous_hash") @db.VarChar(64)
  currentHash   String   @map("current_hash") @db.VarChar(64)

  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@index([eventType], map: "idx_audit_logs_event_type")
  @@index([correlationId], map: "idx_audit_logs_correlation_id")
  @@map("audit_logs")
}

// Operator risk override audit trail
model RiskOverrideLog {
  id                      Int      @id @default(autoincrement())
  opportunityId           String   @map("opportunity_id")
  rationale               String
  approved                Boolean
  originalRejectionReason String   @map("original_rejection_reason")
  overrideAmountUsd       Decimal? @map("override_amount_usd") @db.Decimal(18, 8)
  denialReason            String?  @map("denial_reason")
  createdAt               DateTime @default(now()) @map("created_at")

  @@map("risk_override_logs")
}

// Calibration run history for threshold analysis and audit trail
model CalibrationRun {
  id                          String   @id @default(cuid())
  timestamp                   DateTime @db.Timestamptz
  totalResolvedMatches        Int      @map("total_resolved_matches")
  tiers                       Json     // { autoApprove: CalibrationBand, pendingReview: CalibrationBand, autoReject: CalibrationBand }
  boundaryAnalysis            Json     @map("boundary_analysis") // BoundaryAnalysisEntry[]
  currentAutoApproveThreshold Int      @map("current_auto_approve_threshold")
  currentMinReviewThreshold   Int      @map("current_min_review_threshold")
  recommendations             Json     // string[]
  minimumDataMet              Boolean  @map("minimum_data_met")
  triggeredBy                 String   @map("triggered_by") // "cron" | "operator"
  createdAt                   DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([timestamp])
  @@map("calibration_runs")
}

// Monte Carlo stress test results for portfolio risk validation (Story 9.4)
model StressTestRun {
  id                        String   @id @default(cuid())
  timestamp                 DateTime @db.Timestamptz
  numScenarios              Int      @map("num_scenarios")
  numPositions              Int      @map("num_positions")
  bankrollUsd               Decimal  @map("bankroll_usd") @db.Decimal(20, 8)
  var95                     Decimal  @db.Decimal(20, 8)
  var99                     Decimal  @db.Decimal(20, 8)
  worstCaseLoss             Decimal  @map("worst_case_loss") @db.Decimal(20, 8)
  drawdown15PctProbability  Decimal  @map("drawdown_15pct_probability") @db.Decimal(10, 6)
  drawdown20PctProbability  Decimal  @map("drawdown_20pct_probability") @db.Decimal(10, 6)
  drawdown25PctProbability  Decimal  @map("drawdown_25pct_probability") @db.Decimal(10, 6)
  alertEmitted              Boolean  @default(false) @map("alert_emitted")
  suggestions               Json?    // string[] — parameter tightening suggestions when alert fires
  scenarioDetails           Json     @map("scenario_details") // { percentiles, syntheticResults, volatilities }
  triggeredBy               String   @map("triggered_by") // "cron" | "operator"
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([timestamp])
  @@map("stress_test_runs")
}
